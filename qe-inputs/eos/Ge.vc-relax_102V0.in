&control
    prefix='Ge'
    calculation = 'vc-relax'
    restart_mode = 'from_scratch' !!can also be 'restart'
    tstress = .true.  !!calculate stress
    tprnfor = .true.  !!calculate forces
    outdir = './' !!same folder is ./
    pseudo_dir = './' !!
    etot_conv_thr = 1.0D-4 !!currently placeholders
    forc_conv_thr = 1.0D-3 !!currently placeholders
 /
 &system
    ibrav = 0, !! freeform structure input. In course keep to 0.
    celldm(1) = 11.0874, !! lattice constant expressed in Bohr units; maybe convert all to Angstrom including below NEED TO UPDATE
    nat = 2, !!number of atoms in primitive unit cell
    ntyp = 1, !!types of atoms
    ecutwfc = 110.0, !!
    nbnd = 16, !!number of bands, how many states for e- am I going to calculate; need 10 for 20 electrons; read from pseudopotential file; NUMBER OF VALENCE ELECTRONS TIMES NUMBER OF PRIM CELL ATOMS +30% FOR MARGIN
    occupations = 'smearing',
    degauss=0.002
 /
 &electrons
 diagonalization='david'
 mixing_mode = 'plain'
 mixing_beta = 0.7
 conv_thr = 1.0d-12
/
&ions
ion_dynamics='bfgs' !! name of algorithm
/
&cell
cell_dynamics='bfgs' !! has to match ion dynamics
wmass=145.260 !! total mass of atoms in one unit cell; 2 atoms of Ge is 72.63+72.63
cell_dofree='shape' !! degrees of freedom, can choose to relax all, just volume, certain vectors, etc
 /

ATOMIC_SPECIES
 Ge  72.630  ge_pbe_v1.4.uspp.F.UPF    !!update

CELL_PARAMETERS (alat= 10.87000000)
  -0.000000000   0.500428075   0.500428075
   0.500428075  -0.000000000   0.500428075
   0.500428075   0.500428075   0.000000000

ATOMIC_POSITIONS (alat)
Ge               0.0000000000       -0.0000000000       -0.0000000000
Ge               0.2502140375        0.2502140375        0.2502140375

K_POINTS automatic
 12 12 12 0 0 0

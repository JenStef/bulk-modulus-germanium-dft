&control
    prefix='Ge'
    calculation = 'scf'
    restart_mode = 'from_scratch' !!can also be 'restart'
    tstress = .true.  !!calculate stress
    tprnfor = .true.  !!calculate forces
    outdir = './' !!same folder is ./
    pseudo_dir = './' !!
    etot_conv_thr = 1.0D-4 !!currently placeholders
    forc_conv_thr = 1.0D-3 !!currently placeholders
 /
 &system
    ibrav = 0, !! freeform structure input. In course keep to 0.
    celldm(1) = 10.87, !! lattice constant expressed in Bohr units; maybe convert all to Angstrom including below NEED TO UPDATE
    nat = 2, !!number of atoms in primitive unit cell
    ntyp = 1, !!types of atoms
    ecutwfc = 110.0, !!
    nbnd = 16, !!number of bands, how many states for e- am I going to calculate; need 10 for 20 electrons; read from pseudopotential file; NUMBER OF VALENCE ELECTRONS TIMES NUMBER OF PRIM CELL ATOMS +30% FOR MARGIN
    occupations = 'smearing',
    degauss=0.002
 /
 &electrons
 /

ATOMIC_SPECIES
 Ge  72.630  ge_pbe_v1.4.uspp.F.UPF    !!update

CELL_PARAMETERS alat    !!volume matrix
   0.0 0.5 0.5
   0.5 0.0 0.5
   0.5 0.5 0.0

ATOMIC_POSITIONS alat    !!update coordinates of atoms
 Ge 0.00 0.00 0.00
 Ge 0.25 0.25 0.25

K_POINTS automatic
 12 12 12 0 0 0
